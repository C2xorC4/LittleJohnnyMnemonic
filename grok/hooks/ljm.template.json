{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOOK_RUNNER__ session-start",
            "timeout": 30,
            "env": {
              "JM_VAULT_ROOT": "__JM_VAULT_ROOT__"
            }
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOOK_RUNNER__ user-prompt-submit",
            "timeout": 30,
            "env": {
              "JM_VAULT_ROOT": "__JM_VAULT_ROOT__"
            }
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "search_replace|run_terminal_command|write",
        "hooks": [
          {
            "type": "command",
            "command": "__HOOK_RUNNER__ pre-tool-use",
            "timeout": 10,
            "env": {
              "JM_VAULT_ROOT": "__JM_VAULT_ROOT__"
            }
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOOK_RUNNER__ stop",
            "timeout": 15,
            "env": {
              "JM_VAULT_ROOT": "__JM_VAULT_ROOT__"
            }
          }
        ]
      }
    ]
  }
}
